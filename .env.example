# Environment variables use the NET_ prefix (vendor-agnostic).
# For backward compatibility, old names without NET_ prefix also work
# (e.g., TIMEOUT_CONNECT=10 is equivalent to NET_TIMEOUT_CONNECT=10).
# EOS_ prefix also works for most settings (e.g., EOS_USERNAME=admin).

# Required: Default credentials for network devices
NET_USERNAME=admin
NET_PASSWORD=

# Optional: Default transport (https or http)
NET_TRANSPORT=https

# Optional: Device inventory file path
NET_INVENTORY_FILE=devices.yaml

# Optional: Logging level
NET_LOG_LEVEL=INFO

# Optional: Read-only mode (default: true — blocks all write operations)
NET_READ_ONLY=true

# Optional: Demo mode (use mock devices, no real switches needed)
NET_DEMO_MODE=false

# Optional: Comma-separated list of optional modules to disable
# Available optional modules: evpn_vxlan, security, vrf, bfd, event_monitor, qos
# Example: NET_DISABLED_MODULES=evpn_vxlan,bfd
NET_DISABLED_MODULES=

# Optional: Comma-separated list of modules to load (overrides disabled list)
# NET_ENABLED_MODULES=device,interfaces,routing,vlans

# Optional: Verify eAPI connectivity on first use (runs 'show version')
NET_VERIFY_CONNECTIONS=false

# Optional: Verify TLS certificates for RESTCONF/NX-API connections (default: true)
NET_VERIFY_SSL=true

# Connection keepalive interval (seconds) — idle time before a keep-alive probe is sent
# Increase for high-latency WAN links (range: 10-600)
NET_KEEPALIVE_INTERVAL=60

# Connection timeouts (seconds)
NET_TIMEOUT_CONNECT=10.0
NET_TIMEOUT_SHOW=30.0
NET_TIMEOUT_CONFIG=60.0

# Rate limiting (commands per second per device)
NET_RATE_LIMIT_SHOW=5.0
NET_RATE_LIMIT_CONFIG=1.0

# Cache settings
NET_CACHE_ENABLED=true
NET_CACHE_MAX_ENTRIES=500
NET_CACHE_MAX_MB=50
NET_CACHE_DEFAULT_TTL=30

# Circuit breaker settings (fail-fast for unreachable devices)
NET_CIRCUIT_BREAKER=false
NET_CB_THRESHOLD=3
NET_CB_COOLDOWN=60

# Workflow tool settings
NET_WORKFLOW_TIMEOUT=30
NET_SNAPSHOT_TTL=3600
# NET_SNAPSHOT_DIR=          # Optional dir for persistent snapshots (None = in-memory only)

# Progressive discovery (load only meta-tools at startup, lazy-load on demand)
NET_PROGRESSIVE_DISCOVERY=false

# Observability / metrics collection
NET_METRICS=false

# gNMI settings (requires pygnmi: pip install latticio[gnmi])
NET_GNMI_PORT=6030
NET_GNMI_INSECURE=false
NET_GNMI_TIMEOUT=10
# GNMI_TLS_CERT=
# GNMI_TLS_KEY=
# GNMI_TLS_CA=

# CloudVision Portal settings
# EOS_CVP_URL=https://cvp.example.com
# EOS_CVP_TOKEN=
EOS_CVP_VERIFY_SSL=false

# OAuth 2.1 / JWT authentication (for Streamable HTTP transport only)
# When AUTH_ENABLED=true, Bearer tokens are validated on every HTTP request
# via FastMCP's built-in auth middleware. Stdio transport is never affected.
# Requires: AUTH_ISSUER_URL and AUTH_SECRET_KEY to be set.
AUTH_ENABLED=false
# AUTH_ISSUER_URL=https://auth.example.com
# AUTH_SECRET_KEY=your-jwt-secret-key
# AUTH_REQUIRED_SCOPES=network:read
# AUTH_RESOURCE_SERVER_URL=https://mcp.example.com

# RBAC (requires AUTH_ENABLED=true)
NET_RBAC_ENABLED=false

# Enabled modules (overrides disabled list; comma-separated)
# NET_ENABLED_MODULES=device,interfaces,routing,vlans

# --- Integration settings ---

# NetBox integration
# NETBOX_URL=https://netbox.example.com
# NETBOX_TOKEN=your-netbox-api-token

# ServiceNow integration
# SNOW_INSTANCE=your-instance
# SNOW_USERNAME=api-user
# SNOW_PASSWORD=api-password

# HashiCorp Vault integration
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=your-vault-token

# Prometheus metrics export
NET_PROMETHEUS_ENABLED=false
